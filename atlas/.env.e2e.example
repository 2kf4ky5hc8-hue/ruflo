# Copy to .env.e2e and fill in. Used by Playwright (npm run test:e2e).
# STAGING ONLY. Never put production URLs, the production Supabase ref, or any
# service-role key in here. The guard will refuse to run if it sees production.

# The staging app URL (must contain "atlas-staging" or be localhost).
ATLAS_E2E_BASE_URL=https://atlas-staging-19w.pages.dev

# Optional: the staging Supabase ref, checked by the guard (must NOT be prod).
ATLAS_E2E_SUPABASE_REF=tffpiulparxnxgicdhbr

# Staging test-user credentials (created in the STAGING Supabase project only).
ATLAS_E2E_ADMIN_EMAIL=james+stg-admin@cubittwren.co.uk
ATLAS_E2E_ADMIN_PASSWORD=
ATLAS_E2E_STAFF_EMAIL=james+stg-staff@cubittwren.co.uk
ATLAS_E2E_STAFF_PASSWORD=
ATLAS_E2E_VIEWER_EMAIL=james+stg-viewer@cubittwren.co.uk
ATLAS_E2E_VIEWER_PASSWORD=
