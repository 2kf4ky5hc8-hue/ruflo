# Copy to .env (gitignored) and adjust if your local Postgres differs.
DATABASE_URL=postgres://wealth_os:wealth_os@localhost:5432/wealth_os

# Seed user (only used the first time you run `pnpm db:seed`).
SEED_USER_EMAIL=you@example.com
SEED_USER_NAME=Owner

# Kill switch — set to 'observer' to disable all writes globally.
WEALTH_MODE=advisor

# Optional in dev (defaults are baked in). REQUIRED in production.
# Generate strong values with:  openssl rand -base64 32
# AUTH_SECRET=...
# TOTP_ENC_KEY=...
