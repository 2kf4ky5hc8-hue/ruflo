# Copy this file to `.env` (gitignored). The defaults below let `pnpm dev`
# and `pnpm test` work with zero config; production refuses to boot with
# the weak fallback secrets.

# ── Required everywhere ────────────────────────────────────────────────────

# Postgres connection. The dev script `pnpm db:bootstrap` creates a local
# Postgres + role + db that matches this default.
DATABASE_URL=postgres://wealth_os:wealth_os@localhost:5432/wealth_os

# ── Required in production (dev has built-in fallbacks) ────────────────────

# 32+ char secrets. Generate with: `openssl rand -base64 32`.
# In dev these fall back to a fixed, well-known value so JWTs survive
# restarts; in production the app refuses to boot without strong values.
# AUTH_SECRET=
# TOTP_ENC_KEY=

# ── Optional runtime knobs ─────────────────────────────────────────────────

# Global kill switch. When set to `observer`, submit-proposed-action does
# not write to the database; the risk evaluator still runs so the caller
# learns what *would* have happened.
WEALTH_MODE=advisor

# Friendly app name shown in the layout / emails.
# APP_NAME=Ruflo Wealth

# Dev server port (defaults to 3000).
# PORT=3000

# ── Optional Coach LLM narration ───────────────────────────────────────────

# The Coach computes its report deterministically from your data. If an
# Anthropic key is provided it ALSO produces a readable narration using
# the deterministic numbers as the only source of truth. Without a key,
# the Coach still works — you just get the structured report without prose.
# ANTHROPIC_API_KEY=sk-ant-...
# COACH_MODEL=claude-sonnet-4-6
# COACH_MAX_TOKENS=2000

# ── Coach personal limits (hard caps; 429 when exceeded) ───────────────────

# Max wealth-coach runs per UTC day. Stops accidental click-spam.
# COACH_DAILY_CAP=5

# Max LLM spend per UTC calendar month. The deterministic Coach is free,
# but every narration costs a few cents — this stops a forgetful loop from
# costing real money. (Old name: COACH_MONTHLY_BUDGET_USD, still honoured.)
# COACH_MONTHLY_USD_CAP=2.5

# ── First-run seed (only used by `pnpm db:seed`) ───────────────────────────
SEED_USER_EMAIL=you@example.com
SEED_USER_NAME=Owner

# ── Tests ──────────────────────────────────────────────────────────────────

# `pnpm test` runs unit tests only (no DB). To run the DB-backed integration
# suite you need a live Postgres bootstrapped via `pnpm db:bootstrap`, then:
#   RUN_INTEGRATION=1 pnpm test:integration
# RUN_INTEGRATION=1
