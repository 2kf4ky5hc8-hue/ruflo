# Copy to .env (gitignored) and adjust if your local Postgres differs.
DATABASE_URL=postgres://wealth_os:wealth_os@localhost:5432/wealth_os

# Seed user (only used the first time you run `pnpm db:seed`).
SEED_USER_EMAIL=you@example.com
SEED_USER_NAME=Owner

# Kill switch — set to 'observer' to disable all writes globally.
WEALTH_MODE=advisor

# Optional in dev (defaults are baked in). REQUIRED in production.
# Generate strong values with:  openssl rand -base64 32
# AUTH_SECRET=...
# TOTP_ENC_KEY=...

# Market data (optional). Default 'stub' = deterministic offline prices.
# For live quotes: MARKET_DATA_PROVIDER=fmp and a key from
# https://site.financialmodelingprep.com (free tier available).
MARKET_DATA_PROVIDER=stub
# MARKET_DATA_API_KEY=...

# Daily snapshot daemon. Defaults to a 1-hour tick; lower for local testing:
#   SNAPSHOT_TICK_MS=10000   # tick every 10s
# Production: run `pnpm snapshot:daemon` under systemd / pm2, OR set up cron
# to call `pnpm snapshot:run` once a day. Either path is equivalent.
