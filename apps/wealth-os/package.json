{
  "name": "@ruflo/wealth-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Ruflo Wealth OS — personal wealth command centre (decision-support, not regulated advice)",
  "scripts": {
    "db:up":       "bash scripts/db.sh up",
    "db:down":     "bash scripts/db.sh down",
    "db:reset":    "bash scripts/db.sh reset",
    "db:migrate":  "bash scripts/db.sh migrate",
    "db:seed":     "tsx src/db/seed.ts",
    "db:check":    "tsx scripts/db-check.ts",
    "db:bootstrap":"pnpm db:up && pnpm db:reset && pnpm db:seed && pnpm db:check",
    "db:generate": "drizzle-kit generate",
    "db:push":     "drizzle-kit push",
    "db:studio":   "drizzle-kit studio",
    "typecheck":   "tsc --noEmit",
    "test":        "vitest run",
    "test:watch":  "vitest"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.0",
    "postgres": "^3.4.5",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@claude-flow/hooks": "*",
    "@claude-flow/memory": "*",
    "@claude-flow/security": "*"
  },
  "peerDependenciesMeta": {
    "@claude-flow/hooks":    { "optional": true },
    "@claude-flow/memory":   { "optional": true },
    "@claude-flow/security": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
