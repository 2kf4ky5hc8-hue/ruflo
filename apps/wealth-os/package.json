{
  "name": "@ruflo/wealth-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Ruflo Wealth OS — personal wealth command centre (decision-support, not regulated advice)",
  "scripts": {
    "dev":          "next dev -p ${PORT:-3000}",
    "build":        "next build",
    "start":        "next start -p ${PORT:-3000}",
    "lint":         "next lint",
    "db:up":        "bash scripts/db.sh up",
    "db:down":      "bash scripts/db.sh down",
    "db:reset":     "bash scripts/db.sh reset",
    "db:migrate":   "bash scripts/db.sh migrate",
    "db:ensure":    "bash scripts/db.sh ensure",
    "db:seed":      "tsx src/db/seed.ts",
    "db:check":     "tsx scripts/db-check.ts",
    "db:bootstrap": "pnpm db:up && pnpm db:reset && pnpm db:seed && pnpm db:check",
    "db:generate":  "drizzle-kit generate",
    "db:push":      "drizzle-kit push",
    "db:studio":    "drizzle-kit studio",
    "typecheck":    "tsc --noEmit",
    "test":         "vitest run",
    "test:watch":   "vitest"
  },
  "dependencies": {
    "@auth/core": "^0.37.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/qrcode": "^1.5.5",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.36.0",
    "next": "^15.0.3",
    "next-auth": "5.0.0-beta.25",
    "otpauth": "^9.3.5",
    "postgres": "^3.4.5",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@claude-flow/hooks": "*",
    "@claude-flow/memory": "*",
    "@claude-flow/security": "*"
  },
  "peerDependenciesMeta": {
    "@claude-flow/hooks":    { "optional": true },
    "@claude-flow/memory":   { "optional": true },
    "@claude-flow/security": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.28.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
